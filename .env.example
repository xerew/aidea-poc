# .env.example — root-level env file consumed by docker-compose
# Copy to .env and fill in values

# Django
SECRET_KEY=change-me-to-a-long-random-string

# Frontend API URL
# Local dev (default):     leave unset or http://localhost:8000/api
# VM / remote access:      http://<vm-ip>:8000/api
# Production:              https://yourdomain.com/api
VITE_API_URL=http://localhost:8000/api

# Ollama translation (Phase 2)
# The backend/celery containers talk to Ollama through the ollama-tunnel
# sidecar, which opens an autossh reverse tunnel to the NTUA GPU box where
# Ollama actually runs. Put the SSH private key at
# docker/ollama-tunnel/keys/id_ed25519 (git-ignored) and add its public half
# to the ~/.ssh/authorized_keys of SSH_REMOTE_USER on SSH_REMOTE_HOST.
OLLAMA_MODEL=gemma3-translator
SSH_REMOTE_USER=ngrammatikos
SSH_REMOTE_HOST=147.102.17.66
